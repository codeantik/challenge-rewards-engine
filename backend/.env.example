ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/challenge_rewards
FORUM_TIMEZONE=UTC
JWT_SECRET=change-me-in-.env
JWT_ALGORITHM=HS256
CORS_ORIGINS=["http://localhost:3000"]

# Token-bucket rate limit on POST /api/events: EVENT_RATE_LIMIT_CAPACITY
# requests per user, refilling continuously over EVENT_RATE_LIMIT_WINDOW_SECONDS.
EVENT_RATE_LIMIT_CAPACITY=20
EVENT_RATE_LIMIT_WINDOW_SECONDS=60
