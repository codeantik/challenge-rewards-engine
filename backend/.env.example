ENVIRONMENT=development
# A raw postgres:// or postgresql:// URL from a managed provider (Render,
# Neon, Supabase) is fine here too — app/core/config.py rewrites the scheme
# to postgresql+asyncpg:// and lifts a `?sslmode=require` query param into
# an asyncpg ssl=True connect arg automatically.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/challenge_rewards
FORUM_TIMEZONE=UTC
JWT_SECRET=change-me-in-.env
JWT_ALGORITHM=HS256
CORS_ORIGINS=["http://localhost:3000"]
# Optional, additive to CORS_ORIGINS: a regex for origins that vary per
# deploy, e.g. Vercel preview URLs. Unset disables it.
# CORS_ORIGIN_REGEX=https://your-app-.*\.vercel\.app

# Token-bucket rate limit on POST /api/events: EVENT_RATE_LIMIT_CAPACITY
# requests per user, refilling continuously over EVENT_RATE_LIMIT_WINDOW_SECONDS.
EVENT_RATE_LIMIT_CAPACITY=20
EVENT_RATE_LIMIT_WINDOW_SECONDS=60
